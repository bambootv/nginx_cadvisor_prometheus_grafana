            "targets": [
                {
                    "refId": "A",
                    "expr": "histogram_quantile(0.95, sum by (le) (increase(loki_process_custom_nginxlog_request_duration_seconds_bucket{request=~\"$request\", verb=~\"$verb\", resp_code=~\"$resp_code\"}[$__range])))",
                    "range": false
