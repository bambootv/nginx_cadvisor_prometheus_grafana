        {
            "id": 101,
            "type": "stat",
            "title": "Requests (Selected Range)",
            "gridPos": {
                "h": 4,
                "w": 8,
                "x": 0,
                "y": 1
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum(sum_over_time(loki_nginx_requests_total_by_verb_1m{request=~\"$request\", verb=~\"$verb\", resp_code=~\"$resp_code\"}[$__range]))",
                    "range": false
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "mappings": [],
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green"
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "colorMode": "value",
                "graphMode": "area",
                "justifyMode": "auto",
                "orientation": "horizontal",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "textMode": "auto"
            }
        },
        {
            "id": 102,
            "type": "stat",
            "title": "Server Error Rate (%)",
            "gridPos": {
                "h": 4,
                "w": 8,
                "x": 8,
                "y": 1
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "(sum(sum_over_time(loki_nginx_requests_total_by_verb_1m{resp_code=~\"5..\", request=~\"$request\", verb=~\"$verb\"}[$__range])) / clamp_min(sum(sum_over_time(loki_nginx_requests_total_by_verb_1m{request=~\"$request\", verb=~\"$verb\", resp_code=~\"$resp_code\"}[$__range])), 1)) * 100",
                    "range": false
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green"
                            },
                            {
                                "color": "orange",
                                "value": 1
                            },
                            {
                                "color": "red",
                                "value": 5
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "colorMode": "value",
                "graphMode": "area",
                "justifyMode": "auto",
                "orientation": "horizontal",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "textMode": "auto"
            }
        },
        {
