flowchart TB
    classDef actor fill:#f8fafc,stroke:#475569,color:#0f172a,stroke-width:2px;
    classDef ingress fill:#fff7ed,stroke:#f97316,color:#7c2d12,stroke-width:2px;
    classDef appNode fill:#ecfdf5,stroke:#10b981,color:#064e3b,stroke-width:2px;
    classDef dataNode fill:#fef2f2,stroke:#ef4444,color:#7f1d1d,stroke-width:2px;
    classDef agent fill:#eef2ff,stroke:#6366f1,color:#312e81,stroke-width:2px;
    classDef hostNode fill:#f1f5f9,stroke:#64748b,color:#0f172a,stroke-width:2px;
    classDef backend fill:#f5f3ff,stroke:#8b5cf6,color:#3b0764,stroke-width:2px;
    classDef dashboard fill:#ecfeff,stroke:#06b6d4,color:#164e63,stroke-width:2px;
    classDef tunnel fill:#eff6ff,stroke:#2563eb,color:#1e3a8a,stroke-width:2px;
    classDef cloudNode fill:#faf5ff,stroke:#a855f7,color:#581c87,stroke-width:2px;

    subgraph common["Common VPS (nhiều máy)"]
        host[Host OS\n/proc /sys / rootfs]
        docker[Docker Engine\nsocket + container stats/logs]
        nginx_c[Nginx\nPort 80]
        alloy[Grafana Alloy\nscrape metrics + process logs]
        subgraph project["Project Stack"]
            app[backend / frontend]
            db[db / redis]
        end
    end

    subgraph central["Central VPS"]
        grafana[Grafana\nPort 3000]
        prom[Prometheus\nPort 9090]
        loki[Loki\nPort 3102]
        cfd[cloudflared]
    end

    tailnet[Tailscale tailnet\nhost-level private network]
    cf[Cloudflare Edge + Access]

    user([Public User]) --> nginx_c
    nginx_c -->|"nginx_gateway_net\nproxy_pass http://<stack>_<service>:<port>"| app
    app <-->|"project private network"| db

    alloy -.->|"read host metrics"| host
    alloy -.->|"Docker socket\ncontainer labels + stats"| docker
    nginx_c -.->|"stdout/stderr\naccess logs"| docker
    app -.->|"container logs\ncurrent config: generic"| docker

    alloy -->|"metrics\nCENTRAL_PROM_URL"| tailnet
    alloy -->|"logs\nCENTRAL_LOKI_URL"| tailnet
    tailnet -->|"Central Tailscale IP:9090"| prom
    tailnet -->|"Central Tailscale IP:3102"| loki

    prom -->|"monitoring_swarm_central"| grafana
    loki -->|"monitoring_swarm_central"| grafana

    admin([Admin]) --> cf
    cf --> cfd
    cfd -->|"monitoring_swarm_central"| grafana

    class user,admin actor;
    class nginx_c ingress;
    class app appNode;
    class db dataNode;
    class alloy agent;
    class host,docker hostNode;
    class prom,loki backend;
    class grafana dashboard;
    class tailnet,cfd tunnel;
    class cf cloudNode;

    style common fill:#eff6ff,stroke:#2563eb,stroke-width:2px,color:#1e3a8a
    style project fill:#f0fdf4,stroke:#16a34a,stroke-width:2px,color:#14532d
    style central fill:#faf5ff,stroke:#9333ea,stroke-width:2px,color:#581c87
