
# ============================================================================
# COMMON (Alloy) -> CENTRAL (Prometheus/Loki) endpoints
#
# Dự án dùng Tailscale theo IP.
# Hãy điền trực tiếp IP Tailscale của Central vào URL bên dưới.
# ============================================================================

# Dùng để gắn nhãn dữ liệu theo từng VPS (bắt buộc khi nhiều VPS đổ về Central)
VPS_NAME=vps-01

# Metrics (remote_write -> Prometheus receiver)
# NOTE: Docker `env_file` không expand biến trong URL.
# Common VPS Alloy sẽ đẩy trực tiếp vào Central Prometheus qua IP Tailscale.
CENTRAL_PROM_URL=http://CENTRAL_TAILSCALE_IP:9090/api/v1/write
CENTRAL_PROM_USER=
CENTRAL_PROM_PASSWORD=

# Logs (Loki push)
# Common VPS Alloy sẽ đẩy trực tiếp vào Central Loki qua IP Tailscale.
CENTRAL_LOKI_URL=http://CENTRAL_TAILSCALE_IP:3102/loki/api/v1/push
CENTRAL_LOKI_USER=
CENTRAL_LOKI_PASSWORD=

# Nginx log normalization
NORMALIZE_NGINX_PATH=true


# ============================================================================
# CENTRAL (Grafana + Cloudflare Tunnel)
# ============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
# GF_SERVER_ROOT_URL là URL public mà browser dùng để vào Grafana.
# GF_SERVER_DOMAIN không dùng để Cloudflare route; nó giúp Grafana enforce đúng Host khi bật ENFORCE_DOMAIN.
GF_SERVER_DOMAIN=grafana.tenmien.com
GF_SERVER_ROOT_URL=https://grafana.tenmien.com
GF_SERVER_ENFORCE_DOMAIN=true

# Google OAuth login cho PM.
# Tạo OAuth Client trên Google Cloud với redirect URI:
# https://<GF_SERVER_DOMAIN>/login/google
GF_AUTH_GOOGLE_ENABLED=false
GF_AUTH_GOOGLE_CLIENT_ID=paste-google-client-id
GF_AUTH_GOOGLE_CLIENT_SECRET=paste-google-client-secret
GF_AUTH_GOOGLE_ALLOWED_DOMAINS=your-company.com
GF_AUTH_GOOGLE_ALLOW_SIGN_UP=false

# Bắt buộc nếu dùng flow "admin tạo user trước, PM login Google sau".
# Không bật thì Grafana không match Google user vào user tạo tay -> login fail.
# An toàn vì chỉ dùng 1 provider Google và Google verify email.
GF_AUTH_OAUTH_ALLOW_INSECURE_EMAIL_LOOKUP=true

# Grafana metadata DB.
# User/team/folder permission nằm ở DB này; metrics/logs vẫn nằm ở Prometheus/Loki.
# 2 nhóm biến dưới đây phải dùng cùng name/user/password.
# Postgres đọc POSTGRES_*, Grafana đọc GF_DATABASE_*.
POSTGRES_DB=grafana
POSTGRES_USER=grafana
POSTGRES_PASSWORD=change-me
GF_DATABASE_TYPE=postgres
GF_DATABASE_HOST=postgres:5432
GF_DATABASE_NAME=grafana
GF_DATABASE_USER=grafana
GF_DATABASE_PASSWORD=change-me
GF_DATABASE_SSL_MODE=disable

# Cloudflare Tunnel token không lưu trong .env.
# Tạo bằng Docker secret trên Central manager:
# printf '%s' 'PASTE_TUNNEL_TOKEN_HERE' | docker secret create cf_tunnel_token -
