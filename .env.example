
# ============================================================================
# COMMON (Alloy) -> CENTRAL (Prometheus/Loki) endpoints
#
# Dự án dùng Tailscale theo IP.
# Hãy điền trực tiếp IP Tailscale của Central vào URL bên dưới.
# ============================================================================

# Dùng để gắn nhãn dữ liệu theo từng VPS (bắt buộc khi nhiều VPS đổ về Central)
VPS_NAME=vps-01

# Metrics (remote_write -> Prometheus receiver)
# NOTE: Docker `env_file` không expand biến trong URL.
# Common VPS Alloy sẽ đẩy trực tiếp vào Central Prometheus qua IP Tailscale.
CENTRAL_PROM_URL=http://CENTRAL_TAILSCALE_IP:9090/api/v1/write
CENTRAL_PROM_USER=
CENTRAL_PROM_PASSWORD=

# Logs (Loki push)
# Common VPS Alloy sẽ đẩy trực tiếp vào Central Loki qua IP Tailscale.
CENTRAL_LOKI_URL=http://CENTRAL_TAILSCALE_IP:3102/loki/api/v1/push
CENTRAL_LOKI_USER=
CENTRAL_LOKI_PASSWORD=

# Nginx log normalization
NORMALIZE_NGINX_PATH=true


# ============================================================================
# CENTRAL (Grafana behind Central Nginx)
# ============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
