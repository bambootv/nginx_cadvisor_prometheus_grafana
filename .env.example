
# ============================================================================
# COMMON (Alloy) -> CENTRAL (Prometheus/Loki) endpoints
#
# Dự án dùng Tailscale, nên khuyến nghị trỏ tới MagicDNS của Central.
# Ví dụ: CENTRAL_TAILSCALE_HOST=central
# ============================================================================
CENTRAL_TAILSCALE_HOST=central

# Dùng để gắn nhãn dữ liệu theo từng VPS (bắt buộc khi nhiều VPS đổ về Central)
VPS_NAME=vps-01

# Metrics (remote_write -> Prometheus receiver)
# NOTE: Docker `env_file` không expand biến kiểu `${CENTRAL_TAILSCALE_HOST}`.
CENTRAL_PROM_URL=http://central:9090/api/v1/write
CENTRAL_PROM_USER=
CENTRAL_PROM_PASSWORD=

# Logs (Loki push)
CENTRAL_LOKI_URL=http://central:3102/loki/api/v1/push
CENTRAL_LOKI_USER=
CENTRAL_LOKI_PASSWORD=

# Nginx log normalization
NORMALIZE_NGINX_PATH=true


# ============================================================================
# CENTRAL (Grafana)
# ============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me

