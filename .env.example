# ============================================================================
# ALLOY ENDPOINTS (HYBRID DEFAULT: local Prometheus/Loki in the same stack)
# ============================================================================
GRAFANA_CLOUD_PROM_URL=http://prometheus:9090/api/v1/write
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_API_KEY=
GRAFANA_CLOUD_LOKI_URL=http://loki:3102/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USER=
NORMALIZE_NGINX_PATH=true


# ============================================================================
# HYBRID (PDC + TERRAFORM)
# ============================================================================
PDC_TOKEN=glc_eyJvIjoi...
PDC_CLUSTER=pdc-cluster-id-cua-vps-nay
PDC_GCLOUD_HOSTED_GRAFANA_ID=123456

TF_VAR_grafana_url=https://<your-stack>.grafana.net
TF_VAR_grafana_auth=glsa_...
TF_VAR_vps_name=vps-hanoi-01
TF_VAR_pdc_cluster_id=pdc-cluster-id-cua-vps-nay # Giống PDC_CLUSTER ở trên

